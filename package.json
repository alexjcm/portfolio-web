    "bootstrap": "^5.3.3",
    "i18next": "^24.2.1",
    "next": "16.2.0",
    "next-i18next": "^15.4.1",
    "next-intl": "^4.8.3",
    "pino": "^9.6.0",
    "react": "19.0.0",
    "react-bootstrap": "^2.10.7",
    "react-dom": "19.0.0",
    "react-github-calendar": "^4.5.4",
    "react-i18next": "^15.4.0",
