---
import SiteFooter from '@/components/SiteFooter.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import type { Locale } from '@/i18n/config';
import '@/styles/global.css';

interface Props {
  lang: Locale;
  title?: string;
  description?: string;
  pathname: string;
}

const defaultDescriptionByLocale: Record<Locale, string> = {
  en: 'Portfolio of Alex John Chamba, software engineer focused on Java and TypeScript web development.',
  es: 'Portafolio de Alex John Chamba, ingeniero de software enfocado en desarrollo web con Java y TypeScript.',
};

const { lang, title = 'Alex John Chamba', description = defaultDescriptionByLocale[lang], pathname } = Astro.props;
const normalizedPathname = pathname !== '/' && pathname.endsWith('/') ? pathname.slice(0, -1) : pathname;
const shouldPreloadAvatar = normalizedPathname === '/' || normalizedPathname === '/es';

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://alexjcm.vercel.app');
const socialImageURL = new URL('/assets/logo_dark_aj600.jpg', Astro.url);
const twitterHandle = '@alexjhcm';
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0e1a" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {shouldPreloadAvatar && (
      <link rel="preload" href="/assets/avatar.svg" as="image" type="image/svg+xml" />
    )}
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/logo_dark_aj167.jpg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <!-- Font Preloading -->
    <!-- Alternate Locales -->
    {lang === 'en' ? (
      <link rel="alternate" hreflang="es" href={new URL('/es' + pathname.replace(/^\/es/, ''), Astro.site || 'https://alexjcm.vercel.app')} />
    ) : (
      <link rel="alternate" hreflang="en" href={new URL(pathname.replace(/^\/es/, '') || '/', Astro.site || 'https://alexjcm.vercel.app')} />
    )}
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site || 'https://alexjcm.vercel.app')} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'es_ES'} />
    <meta property="og:locale:alternate" content={lang === 'en' ? 'es_ES' : 'en_US'} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Alex John Chamba",
      "url": "https://alexjcm.vercel.app",
      "image": socialImageURL,
      "jobTitle": "Software Engineer",
      "sameAs": [
        "https://github.com/alexjhcm",
        "https://linkedin.com/in/alexjhcm",
        "https://twitter.com/alexjhcm"
      ],
      "description": description
    })} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:site" content={twitterHandle} />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />


    <!-- Anti-FOUC: resolve theme before first paint -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: light)').matches
              ? 'light'
              : 'dark';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <!-- Aurora background blobs -->
    <div class="aurora-blob-3" aria-hidden="true"></div>
    <div class="noise" aria-hidden="true"></div>

    <SiteHeader locale={lang} pathname={pathname} />
    <main class="container">
      <slot />
    </main>
    <SiteFooter locale={lang} />
  </body>
</html>

<style>
  .container {
    box-sizing: border-box;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    min-height: 100vh;
    padding-top: calc(var(--nav-height) + 2rem);
    padding-inline: 1.25rem;
    padding-bottom: 3rem;
  }
</style>
