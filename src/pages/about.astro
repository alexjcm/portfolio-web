---
import TagCloud from '@/components/about/TagCloud.astro';
import GitHubSnake from '@/components/about/GitHubSnake.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getMessages } from '@/i18n/messages';
import { getLocalizedPath } from '@/i18n/routing';

const t = getMessages('en').about;

const tags = [
  'Java', 'Spring Boot', 'Node.js', 'Express',
  'PostgreSQL', 'MongoDB', 'Redis', 'Docker',
  'Git', 'TypeScript', 'Astro', 'Testing',
];

const skills = ['Java', 'TypeScript', 'Node.js', 'Spring Boot', 'React', 'Astro'];
const tools  = ['Docker', 'Git', 'VS Code', 'Postman', 'Linux', 'Vercel'];

const experience = [
  {
    role: 'Software Engineer',
    company: '[Company Placeholder]',
    period: '2023 – Present',
    description: 'Full-stack development with Java Spring Boot and React. REST API design, PostgreSQL, Docker.',
  },
  {
    role: 'Backend Developer',
    company: '[Company Placeholder]',
    period: '2022 – 2023',
    description: 'Node.js microservices, API integrations, CI/CD pipelines.',
  },
];

const title = 'About – Alex John Chamba';
---

<BaseLayout lang="en" pathname={Astro.url.pathname} title={title}>

  <!-- Intro + TagCloud -->
  <section class="section intro-grid">
    <div class="intro-text">
      <span class="section-label">about me</span>
      <h1 class="section-title">{t.whoQ} <span class="accent">{t.iamQ}</span></h1>
      <p class="bio">
        {t.iam} <strong>Alex John Chamba</strong>. {t.iamSummary}
      </p>
      <p class="bio">
        I'm passionate about building performant, maintainable software and sharing what I learn.
        When not coding, I enjoy exploring new tools and contributing to open source.
      </p>
      <a href={getLocalizedPath('en', 'contact')} class="btn btn-primary cta">
        Get in touch →
      </a>
    </div>

    <TagCloud id="tag-cloud-en" tags={tags} />
  </section>

  <!-- Experience -->
  <section class="section">
    <span class="section-label">career</span>
    <h2 class="section-title">Experience</h2>
    <ul class="exp-list">
      {experience.map((item) => (
        <li class="exp-item glass">
          <div class="exp-header">
            <div>
              <h3 class="exp-role">{item.role}</h3>
              <p class="exp-company">{item.company}</p>
            </div>
            <span class="exp-period mono text-muted">{item.period}</span>
          </div>
          <p class="exp-desc">{item.description}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- Skills & Tools -->
  <section class="section">
    <span class="section-label">tools</span>
    <h2 class="section-title">Skills &amp; Tools</h2>

    <div class="stack-grid">
      <div class="stack-group">
        <h3 class="stack-label">{t.skills}</h3>
        <ul class="chip-list" role="list">
          {skills.map((s) => <li class="badge">{s}</li>)}
        </ul>
      </div>
      <div class="stack-group">
        <h3 class="stack-label">{t.tools} {t.iUse}</h3>
        <ul class="chip-list" role="list">
          {tools.map((s) => <li class="badge">{s}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Contact row -->
  <section class="section contact-row">
    <span class="section-label">contact</span>
    <h2 class="section-title">Let's connect</h2>
    <div class="link-row">
      <a href="https://github.com/alexjcm" target="_blank" rel="noopener noreferrer" class="btn btn-outline">GitHub</a>
      <a href="https://www.linkedin.com/in/alex-john-chamba-macas/" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
      <a href="mailto:alexjohnchamba@gmail.com" class="btn btn-primary">Email me</a>
    </div>
  </section>

  <!-- GitHub Snake Animation -->
  <GitHubSnake />

</BaseLayout>

<style>
  .accent { color: var(--accent); }

  /* ── Intro grid ── */
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    padding-top: clamp(1.5rem, 4vw, 3rem);
  }

  @media (min-width: 768px) {
    .intro-grid {
      grid-template-columns: 1.1fr 1fr;
    }
  }

  .intro-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bio {
    color: var(--text-muted);
    line-height: 1.8;
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
  }

  .cta { align-self: flex-start; margin-top: 0.25rem; }

  /* ── Experience ── */
  .exp-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    list-style: none;
  }

  .exp-item {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .exp-role {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .exp-company {
    font-size: 0.88rem;
    color: var(--accent);
    margin-top: 0.1rem;
    font-family: var(--font-mono);
  }

  .exp-period {
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .exp-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* ── Skills ── */
  .stack-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .stack-grid { grid-template-columns: 1fr 1fr; }
  }

  .stack-group { display: flex; flex-direction: column; gap: 0.75rem; }

  .stack-label {
    font-size: 0.82rem;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }

  /* ── Contact row ── */
  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
