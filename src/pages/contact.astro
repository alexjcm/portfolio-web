---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getMessages } from '@/i18n/messages';

const t = getMessages('en').contact;
const title = 'Contact – Alex John Chamba';
---

<BaseLayout lang="en" pathname={Astro.url.pathname} title={title}>
  <section class="section contact-page">
    <span class="section-label">contact</span>
    <h1 class="section-title">{t.sendEmail}</h1>
    <p class="subtitle">The quickest way to reach me is by email. I'll get back to you as soon as possible.</p>

    <div class="contact-cards">
      <a href="mailto:alexjohnchamba@gmail.com" class="contact-card glass">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7">
          </path>
        </svg>
        <div>
          <strong>Email</strong>
          <span>alexjohnchamba@gmail.com</span>
        </div>
      </a>

      <a
        href="https://www.linkedin.com/in/alex-john-chamba-macas/"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card glass"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          >
          </path>
        </svg>
        <div>
          <strong>LinkedIn</strong>
          <span>alex-john-chamba-macas</span>
        </div>
      </a>

      <a href="https://dev.to/alexjcm" target="_blank" rel="noopener noreferrer" class="contact-card glass">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6l.02 2.44.04 2.45.56-.02c.41 0 .63-.07.83-.26.24-.24.26-.36.26-2.2 0-1.91-.02-1.96-.29-2.18zM0 4.94v14.12h24V4.94H0zM8.56 15.3c-.44.58-1.06.77-2.53.77H4.71V8.53h1.4c1.67 0 2.16.18 2.6.9.27.43.29.6.32 2.57.05 2.23-.02 2.73-.47 3.3zm5.09-5.47h-2.47v1.77h1.52v1.28l-1.52.01v1.76h2.84v1.42H9.72V8.53h4.97v1.3zm6.34 5.23c-.81 1.6-1.53 2.95-1.58 3.01-.06.06-1.15.04-1.33-.03-.16-.07-1.48-2.52-3.13-5.87l-1.35-2.73h1.72l1.92 4.07c1.06 2.22 1.94 4.09 1.96 4.14.02.04.53-1.01 1.13-2.31l1.1-2.4h1.74l-2.18 4.79v.03z"
          >
          </path>
        </svg>
        <div>
          <strong>Dev.to</strong>
          <span>dev.to/alexjcm</span>
        </div>
      </a>

      <a href="https://github.com/alexjcm" target="_blank" rel="noopener noreferrer" class="contact-card glass">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
          >
          </path>
        </svg>
        <div>
          <strong>GitHub</strong>
          <span>github.com/alexjcm</span>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding-top: clamp(1.5rem, 4vw, 3rem);
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1rem;
    margin-bottom: 2rem;
    max-width: 50ch;
  }

  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 520px;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text);
    transition:
      background var(--transition),
      box-shadow var(--transition),
      transform var(--transition);
  }

  .contact-card:hover {
    background: var(--accent-dim);
    box-shadow: var(--glow);
    transform: translateX(4px);
  }

  .contact-card svg {
    flex-shrink: 0;
    color: var(--accent);
  }

  .contact-card div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .contact-card strong {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .contact-card span {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }
</style>
