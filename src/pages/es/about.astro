---
import GitHubSnake from '@/components/about/GitHubSnake.astro';
import { ABOUT_TAG_SPHERE_CONFIG } from '@/components/about/tagSphereConfig';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getMessages } from '@/i18n/messages';
import { getLocalizedPath } from '@/i18n/routing';
import '@/styles/about-page.css';
import TagSphere from 'tag-sphere/astro';

const t = getMessages('es').about;

const tags = [
  'Java',
  'Spring Boot',
  'Node.js',
  'Express',
  'PostgreSQL',
  'MongoDB',
  'Redis',
  'Docker',
  'Git',
  'TypeScript',
  'Astro',
  'Testing',
];

const skills = ['Java', 'TypeScript', 'Node.js', 'Spring Boot', 'React', 'Astro'];
const tools = ['Docker', 'Git', 'VS Code', 'Postman', 'Linux', 'Vercel'];

const experience = [
  {
    role: 'Ingeniero de Software',
    company: '[Empresa Placeholder]',
    period: '2023 – Presente',
    description: 'Desarrollo full-stack con Java Spring Boot y React. Diseño de APIs REST, PostgreSQL, Docker.',
  },
  {
    role: 'Desarrollador Backend',
    company: '[Empresa Placeholder]',
    period: '2022 – 2023',
    description: 'Microservicios en Node.js, integraciones de API, pipelines CI/CD.',
  },
];

const title = 'Sobre mí – Alex John Chamba';
---

<BaseLayout lang="es" pathname={Astro.url.pathname} title={title}>
  <!-- Intro + TagSphere -->
  <section class="section intro-grid">
    <div class="intro-text">
      <span class="section-label">sobre mí</span>
      <h1 class="section-title">{t.whoQ} <span class="accent">{t.iamQ}</span></h1>
      <p class="bio">
        {t.iam}
        <strong>Alex John Chamba</strong>. {t.iamSummary}
      </p>
      <p class="bio">
        Me apasiona construir software mantenible y de alto rendimiento, y compartir lo que aprendo. Cuando no estoy
        programando, disfruto explorando nuevas herramientas y contribuyendo al código abierto.
      </p>
      <a href={getLocalizedPath('es', 'contact')} class="btn btn-primary cta">Contáctame →</a>
    </div>

    <TagSphere
      id="tag-sphere-es"
      class="about-tag-sphere"
      aria-label="Esfera de etiquetas"
      tags={tags}
      radius={ABOUT_TAG_SPHERE_CONFIG.radius}
      speed={ABOUT_TAG_SPHERE_CONFIG.speed}
      direction={ABOUT_TAG_SPHERE_CONFIG.direction}
    />
  </section>

  <!-- Experiencia -->
  <section class="section">
    <span class="section-label">carrera</span>
    <h2 class="section-title">Experiencia</h2>
    <ul class="exp-list">
      {
        experience.map((item) => (
          <li class="exp-item glass">
            <div class="exp-header">
              <div>
                <h3 class="exp-role">{item.role}</h3>
                <p class="exp-company">{item.company}</p>
              </div>
              <span class="exp-period mono text-muted">{item.period}</span>
            </div>
            <p class="exp-desc">{item.description}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Habilidades & Herramientas -->
  <section class="section">
    <span class="section-label">herramientas</span>
    <h2 class="section-title">{t.skills} &amp; {t.tools}</h2>

    <div class="stack-grid">
      <div class="stack-group">
        <h3 class="stack-label">{t.skills}</h3>
        <ul class="chip-list" role="list">
          {skills.map((s) => <li class="badge">{s}</li>)}
        </ul>
      </div>
      <div class="stack-group">
        <h3 class="stack-label">{t.tools} {t.iUse}</h3>
        <ul class="chip-list" role="list">
          {tools.map((s) => <li class="badge">{s}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Contacto -->
  <section class="section contact-row">
    <span class="section-label">contacto</span>
    <h2 class="section-title">Conectemos</h2>
    <div class="link-row">
      <a href="https://github.com/alexjcm" target="_blank" rel="noopener noreferrer" class="btn btn-outline">GitHub</a>
      <a
        href="https://www.linkedin.com/in/alex-john-chamba-macas/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline"
      >
        LinkedIn
      </a>
      <a href="mailto:alexjohnchamba@gmail.com" class="btn btn-primary">Escríbeme</a>
    </div>
  </section>

  <!-- GitHub Snake Animation -->
  <GitHubSnake />
</BaseLayout>
