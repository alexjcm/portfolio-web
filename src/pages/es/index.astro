---
import { getCollection } from 'astro:content';
import Hero from '@/components/Hero.astro';
import TechStack from '@/components/TechStack.astro';
import AboutPreview from '@/components/AboutPreview.astro';
import Contact from '@/components/Contact.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Alex John Chamba · Ingeniero de Software';

const allProjects = await getCollection('projects');
const featured = allProjects.filter((p) => p.data.featured).slice(0, 3);
---

<BaseLayout lang="es" pathname={Astro.url.pathname} title={title}>
  <Hero locale="es" />
  <TechStack locale="es" />

  <!-- Proyectos Destacados -->
  <section class="section featured-section">
    <span class="section-label">trabajo</span>
    <div class="featured-header">
      <h2 class="section-title">Proyectos Destacados</h2>
      <a href="/es/projects" class="btn btn-outline view-all">Ver todos →</a>
    </div>
    <div class="grid-3">
      {
        featured.map((project) => (
          <ProjectCard
            name={project.data.name.es}
            description={project.data.description.es}
            tech={project.data.tech}
            image={project.data.imageProjectLink}
            projectLink={project.data.projectLink}
            demoLink={project.data.demoLink || undefined}
            featured={project.data.featured}
            loading="eager"
          />
        ))
      }
    </div>
  </section>

  <AboutPreview locale="es" />
  <Contact locale="es" />
</BaseLayout>

<style>
  .featured-section {
    padding-top: clamp(2.5rem, 5vw, 4rem);
  }

  .featured-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .featured-header .section-title {
    margin-bottom: 0;
  }

  .view-all {
    font-size: 0.85rem;
    padding: 0.35rem 0.9rem;
    white-space: nowrap;
  }
</style>
