---
interface Props {
  tags: string[];
  id: string;
}

const { tags, id } = Astro.props;
---

<div class="tagCloud" id={id} data-tags={JSON.stringify(tags)} aria-label="Tag cloud" role="img">
  <div class="surface"></div>
</div>

<script is:inline>
  const clouds = document.querySelectorAll('.tagCloud');

  clouds.forEach((cloud) => {
    if (cloud.dataset.ready === 'true') {
      return;
    }

    cloud.dataset.ready = 'true';
    const tags = JSON.parse(cloud.dataset.tags || '[]');
    const surface = cloud.querySelector('.surface');
    if (!surface || !tags.length) return;

    const nodes = tags.map((label) => {
      const node = document.createElement('span');
      node.className = 'tag';
      node.textContent = label;
      surface.appendChild(node);
      return node;
    });

    const radius = 110;
    let angle = 0;

    const render = () => {
      angle += 0.0035;
      nodes.forEach((node, index) => {
        const alpha = angle + (index / nodes.length) * Math.PI * 2;
        const x = Math.cos(alpha) * radius;
        const y = Math.sin(alpha) * (radius * 0.58);
        const depth = (Math.sin(alpha) + 1) / 2;
        const scale = 0.75 + depth * 0.4;

        node.style.transform = `translate(${x}px, ${y}px) scale(${scale})`;
        node.style.opacity = `${0.4 + depth * 0.6}`;
        node.style.zIndex = String(Math.round(depth * 10));
      });

      window.requestAnimationFrame(render);
    };

    render();
  });
</script>

<style>
  .tagCloud {
    position: relative;
    width: 100%;
    min-height: 300px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: linear-gradient(135deg, #ffffff 0%, #eef8f7 100%);
    overflow: hidden;
  }

  .surface {
    position: absolute;
    left: 50%;
    top: 50%;
  }

  .tag {
    position: absolute;
    left: -2rem;
    top: -0.7rem;
    white-space: nowrap;
    border: 1px solid #b8d8d4;
    background: #f7fffe;
    color: #155e57;
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 600;
    transform-origin: center;
  }
</style>
