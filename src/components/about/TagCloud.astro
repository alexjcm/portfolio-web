---
interface Props {
  tags: string[];
  id: string;
}

const { tags, id } = Astro.props;
---

<div class="tagCloud" id={id} data-tags={JSON.stringify(tags)} aria-label="Tag cloud" role="img">
  <div class="surface"></div>
</div>

<script is:inline>
  (function () {
    var clouds = document.querySelectorAll('.tagCloud');

    clouds.forEach(function (cloud) {
      if (cloud.dataset.ready === 'true') return;

      cloud.dataset.ready = 'true';
      var tags = JSON.parse(cloud.dataset.tags || '[]');
      var surface = cloud.querySelector('.surface');
      if (!surface || !tags.length) return;

      var nodes = tags.map(function (label) {
        var node = document.createElement('span');
        node.className = 'tag';
        node.textContent = label;
        surface.appendChild(node);
        return node;
      });

      var radius = 110;
      var angle = 0;

      var render = function () {
        angle += 0.0035;
        nodes.forEach(function (node, index) {
          var alpha = angle + (index / nodes.length) * Math.PI * 2;
          var x = Math.cos(alpha) * radius;
          var y = Math.sin(alpha) * (radius * 0.58);
          var depth = (Math.sin(alpha) + 1) / 2;
          var scale = 0.75 + depth * 0.4;

          node.style.transform = 'translate(' + x + 'px, ' + y + 'px) scale(' + scale + ')';
          node.style.opacity = String(0.4 + depth * 0.6);
          node.style.zIndex = String(Math.round(depth * 10));
        });

        window.requestAnimationFrame(render);
      };

      render();
    });
  })();
</script>

<style>
  /* 8a — redesigned for dark mode + glassmorphism tokens */
  .tagCloud {
    position: relative;
    width: 100%;
    min-height: 300px;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    overflow: hidden;
    box-shadow: var(--glass-shadow);
  }

  .surface {
    position: absolute;
    left: 50%;
    top: 50%;
  }

  .tag {
    position: absolute;
    left: -2rem;
    top: -0.7rem;
    white-space: nowrap;
    border: 1px solid var(--surface-border);
    background: var(--accent-dim);
    color: var(--accent-strong);
    border-radius: var(--radius-pill);
    padding: 0.18rem 0.65rem;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    font-weight: 600;
    transform-origin: center;
  }

  /* Light mode override via CSS only — no JS branching */
  :root[data-theme='light'] .tagCloud {
    background: rgba(255, 255, 255, 0.65);
  }
</style>
