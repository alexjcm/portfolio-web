---
import Typewriter from '@/components/home/Typewriter.astro';
import type { Locale } from '@/i18n/config';
import { getMessages } from '@/i18n/messages';
import { getLocalizedPath } from '@/i18n/routing';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale).home;
const tc = getMessages(locale).common;

const phrases = [t.javaDeveloper, t.engineer, t.reactDeveloper];

// DiceBear avatar — seed fixed to developer name, fetched as static URL (zero client JS)
const avatarUrl = 'https://api.dicebear.com/9.x/initials/svg?seed=AJ&backgroundColor=b6e3f4';

const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/alexjcm',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/alex-john-chamba-macas/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'Dev.to',
    href: 'https://dev.to/alexjcm',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6l.02 2.44.04 2.45.56-.02c.41 0 .63-.07.83-.26.24-.24.26-.36.26-2.2 0-1.91-.02-1.96-.29-2.18zM0 4.94v14.12h24V4.94H0zM8.56 15.3c-.44.58-1.06.77-2.53.77H4.71V8.53h1.4c1.67 0 2.16.18 2.6.9.27.43.29.6.32 2.57.05 2.23-.02 2.73-.47 3.3zm5.09-5.47h-2.47v1.77h1.52v1.28l-1.52.01v1.76h2.84v1.42H9.72V8.53h4.97v1.3zm6.34 5.23c-.81 1.6-1.53 2.95-1.58 3.01-.06.06-1.15.04-1.33-.03-.16-.07-1.48-2.52-3.13-5.87l-1.35-2.73h1.72l1.92 4.07c1.06 2.22 1.94 4.09 1.96 4.14.02.04.53-1.01 1.13-2.31l1.1-2.4h1.74l-2.18 4.79v.03z"/></svg>`,
  },
  {
    label: 'Twitter',
    href: 'https://twitter.com/alexjhcm',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.632L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>`,
  },
];
---

<section class="hero">
  <!-- Left: text content -->
  <div class="hero-content">
    <p class="greeting mono text-muted">{t.greeting} 👋</p>

    <h1 class="hero-name">
      {t.iam} <span class="name-highlight">Alex John Chamba</span>
    </h1>

    <div class="role-line">
      <Typewriter id={`tw-hero-${locale}`} phrases={phrases} />
    </div>

    <p class="hero-desc">{t.myInterest}</p>

    <div class="hero-cta">
      <a href={getLocalizedPath(locale, 'projects')} class="btn btn-primary">
        {tc.navbar.projects} →
      </a>
      <a href={getLocalizedPath(locale, 'contact')} class="btn btn-outline">
        {tc.navbar.contact}
      </a>
    </div>

    <ul class="socials" role="list" aria-label="Social links">
      {socials.map((s) => (
        <li>
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label={s.label}
          >
            <Fragment set:html={s.icon} />
            <span>{s.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Right: avatar -->
  <div class="hero-visual" aria-hidden="true">
    <div class="avatar-ring">
      <img
        src={avatarUrl}
        alt="Alex John Chamba avatar"
        width="240"
        height="240"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="avatar"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(2rem, 5vw, 4rem);
    padding-block: clamp(2rem, 6vw, 5rem);
    min-height: calc(100dvh - var(--nav-height) - 4rem);
  }

  /* ── Left content ── */
  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 600px;
  }

  .greeting {
    font-size: 0.9rem;
    letter-spacing: 0.06em;
  }

  .hero-name {
    line-height: 1.1;
    color: var(--text);
  }

  .name-highlight {
    display: block;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-strong) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .role-line {
    min-height: 2.4rem;
  }

  .hero-desc {
    color: var(--text-muted);
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
    line-height: 1.75;
    max-width: 52ch;
  }

  /* ── CTA buttons ── */
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  /* ── Social links ── */
  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.25rem;
    list-style: none;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition), background var(--transition), border-color var(--transition);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .social-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  /* ── Avatar ── */
  .hero-visual {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar-ring {
    position: relative;
    width: 250px;
    height: 250px;
    border-radius: 50%;
    padding: 4px;
    background: linear-gradient(135deg, var(--accent) 0%, rgba(168, 85, 247, 0.6) 100%);
  }

  .avatar-ring::before {
    content: '';
    position: absolute;
    inset: -12px;
    border-radius: 50%;
    background: var(--accent-dim);
    filter: blur(20px);
    z-index: -1;
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    background: #b6e3f4;
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse;
      align-items: flex-start;
      min-height: auto;
      padding-block: 2rem 1rem;
    }

    .hero-visual {
      align-self: center;
    }

    .avatar-ring {
      width: 140px;
      height: 140px;
    }

    .name-highlight {
      display: inline;
    }
  }
</style>
