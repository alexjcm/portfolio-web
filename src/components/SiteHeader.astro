---
import { localeLabels, type Locale } from '@/i18n/config';
import { getMessages } from '@/i18n/messages';
import {
  getLocalizedPath,
  isRouteActive,
  switchLocalePath,
  type NavRoute,
} from '@/i18n/routing';

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const t = getMessages(locale).common;
const otherLocale: Locale = locale === 'en' ? 'es' : 'en';
const localeHref = switchLocalePath(pathname, otherLocale);
const localeSwitchAriaLabel = locale === 'en' ? 'Switch to Spanish' : 'Cambiar a inglés';

const routes: { key: NavRoute; label: string }[] = [
  { key: 'home',     label: t.navbar.home },
  { key: 'projects', label: t.navbar.projects },
  { key: 'about',    label: t.navbar.about },
  { key: 'contact',  label: t.navbar.contact },
];
---

<header class="header" id="site-header">
  <div class="inner">
    <!-- Brand / Logo -->
    <a class="brand" href={getLocalizedPath(locale, 'home')} aria-label={locale === 'en' ? 'Go to home' : 'Ir a inicio'}>
      <picture>
        <source
          media="(prefers-color-scheme: dark)"
          srcset="/assets/logo_dark_aj167.jpg 167w, /assets/logo_dark_aj600.jpg 600w"
        />
        <img
          src="/assets/logo_light_aj167.jpg"
          srcset="/assets/logo_light_aj167.jpg 167w, /assets/logo_light_aj600.jpg 600w"
          sizes="2rem"
          width="32"
          height="32"
          alt="AJ logo"
          loading="eager"
          decoding="async"
        />
      </picture>
    </a>

    <!-- Primary nav -->
    <nav aria-label="Primary navigation">
      <ul class="navList">
        {
          routes.map((route) => (
            <li>
              <a
                href={getLocalizedPath(locale, route.key)}
                class={isRouteActive(pathname, locale, route.key) ? 'navLink active' : 'navLink'}
              >
                {route.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Right controls -->
    <div class="controls">
      <!-- Language switcher -->
      <a class="localeSwitch" href={localeHref} aria-label={localeSwitchAriaLabel}>
        {localeLabels[otherLocale]}
      </a>

      <!-- Theme toggle -->
      <button class="themeToggle" id="theme-toggle" aria-label="Toggle colour theme" type="button">
        <!-- Sun icon (shown in dark mode) -->
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Hamburger menu (mobile) -->
<button class="menuToggle" id="menu-toggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-nav" type="button">
  <span></span><span></span><span></span>
</button>

<!-- Mobile nav drawer -->
<nav class="mobileNav" id="mobile-nav" aria-label="Mobile navigation" aria-hidden="true">
  <ul>
    {
      routes.map((route) => (
        <li>
          <a
            href={getLocalizedPath(locale, route.key)}
            class={isRouteActive(pathname, locale, route.key) ? 'active' : ''}
          >
            {route.label}
          </a>
        </li>
      ))
    }
    <li>
      <a href={localeHref} class="mobileLocale">
        {localeLabels[otherLocale]}
      </a>
    </li>
  </ul>
</nav>

<script is:inline>
  /* ── Theme toggle ── */
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var current = document.documentElement.getAttribute('data-theme');
      var next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (_) {}
    });
  })();

  /* ── Mobile menu toggle ── */
  (function () {
    var toggle = document.getElementById('menu-toggle');
    var nav    = document.getElementById('mobile-nav');
    if (!toggle || !nav) return;
    toggle.addEventListener('click', function () {
      var open = nav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
      nav.setAttribute('aria-hidden', String(!open));
    });
  })();
</script>

<style>
  /* ── Navbar shell ── */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: var(--glass-bg);
    border-bottom: 1px solid var(--glass-border);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.20);
  }

  .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.25rem;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* ── Brand / Logo ── */
  .brand {
    display: inline-flex;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-pill);
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    background: var(--surface);
    transition: box-shadow var(--transition);
  }

  .brand:hover {
    box-shadow: var(--glow);
  }

  .brand picture {
    display: flex;
    width: 100%;
    height: 100%;
  }

  .brand img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Nav links ── */
  nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .navList {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.2rem;
  }

  .navLink {
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.35rem 0.8rem;
    border-radius: var(--radius-pill);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color var(--transition), background var(--transition);
  }

  .navLink:hover {
    color: var(--text);
    background: var(--surface-hover);
  }

  .navLink.active {
    color: var(--accent);
    background: var(--accent-dim);
    font-weight: 600;
  }

  /* ── Right controls ── */
  .controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    margin-left: auto;
  }

  .localeSwitch {
    text-decoration: none;
    color: var(--text-muted);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-pill);
    padding: 0.3rem 0.75rem;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    background: var(--glass-bg);
    transition: color var(--transition), background var(--transition);
    white-space: nowrap;
  }

  .localeSwitch:hover {
    color: var(--accent);
    background: var(--accent-dim);
  }

  .themeToggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--text-muted);
    cursor: pointer;
    transition: color var(--transition), background var(--transition), box-shadow var(--transition);
    flex-shrink: 0;
  }

  .themeToggle:hover {
    color: var(--accent);
    background: var(--accent-dim);
    box-shadow: var(--glow);
  }

  /* Icon visibility tied to theme */
  :root[data-theme='dark']  .icon-moon { display: none; }
  :root[data-theme='light'] .icon-sun  { display: none; }
  /* Default dark */
  .icon-moon { display: none; }

  /* ── Hamburger (mobile only) ── */
  .menuToggle {
    display: none;
    position: fixed;
    top: calc((var(--nav-height) - 2rem) / 2);
    right: 1.25rem;
    z-index: 110;
    width: 2rem;
    height: 2rem;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
  }

  .menuToggle span {
    display: block;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform var(--transition), opacity var(--transition);
  }

  /* ── Mobile nav drawer ── */
  .mobileNav {
    display: none;
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    z-index: 99;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--glass-border);
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition), transform var(--transition);
  }

  .mobileNav.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mobileNav ul {
    list-style: none;
    margin: 0;
    padding: 0.75rem 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobileNav a {
    display: block;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius-md);
    color: var(--text-muted);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: background var(--transition), color var(--transition);
  }

  .mobileNav a:hover,
  .mobileNav a.active {
    background: var(--accent-dim);
    color: var(--accent);
  }

  .mobileLocale {
    font-family: var(--font-mono);
    font-size: 0.85rem !important;
    letter-spacing: 0.04em;
    margin-top: 0.5rem;
    border-top: 1px solid var(--glass-border);
    padding-top: 0.75rem !important;
  }

  /* ── Responsive: mobile breakpoint ── */
  @media (max-width: 640px) {
    nav { display: none; }
    .controls .localeSwitch { display: none; }
    .menuToggle { display: flex; }
    .mobileNav { display: block; }
  }
</style>
