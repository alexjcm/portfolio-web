---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  description: string;
  tech: string[];
  image: string;
  projectLink: string;
  demoLink?: string;
  featured?: boolean;
  loading?: 'lazy' | 'eager';
}

const { name, description, tech, image, projectLink, demoLink, featured = false, loading = 'lazy' } = Astro.props;
---

<article class={`project-card glass ${featured ? 'featured' : ''}`}>
  <div class="card-image">
    <Image
      src={`/assets/projects/${image}`}
      alt={`${name} screenshot`}
      width={600}
      height={340}
      widths={[360, 600, 800]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 600px"
      loading={loading}
      decoding="async"
      format="webp"
      quality="high"
    />
  </div>

  <!-- Body -->
  <div class="card-body">
    <h3 class="card-title">{name}</h3>
    <p class="card-desc">{description}</p>

    <!-- Tech badges -->
    <ul class="tech-list" role="list" aria-label="Technologies used">
      {tech.map((t) => <li class="badge">{t}</li>)}
    </ul>

    <!-- Links -->
    <div class="card-links">
      <a
        href={projectLink}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline card-btn"
        aria-label={`View ${name} source on GitHub`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
          >
          </path>
        </svg>
        GitHub
      </a>

      {
        demoLink && (
          <a
            href={demoLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary card-btn"
            aria-label={`View ${name} live demo`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <>
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </>
            </svg>
            Demo
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      transform var(--transition-slow),
      box-shadow var(--transition-slow);
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  /* Featured ring */
  .project-card.featured {
    border-color: rgba(94, 234, 212, 0.25);
  }

  /* Image area */
  .card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface);
    position: relative;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .project-card:hover .card-image img {
    transform: scale(1.04);
  }

  /* Fallback when image fails to load */
  .card-image.no-img {
    min-height: 120px;
    background: linear-gradient(135deg, var(--aurora-1), var(--aurora-2));
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    flex: 1;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .card-desc {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.7;
    flex: 1;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
  }

  .card-links {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .card-btn {
    font-size: 0.82rem;
    padding: 0.55rem 1.1rem;
    gap: 0.35rem;
    min-width: 4.5rem;
    justify-content: center;
  }
</style>
